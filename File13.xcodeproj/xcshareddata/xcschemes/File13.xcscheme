   <TestAction
      buildConfiguration = "Debug"
      selectedDebuggerIdentifier = "Xcode.DebuggerFoundation.Debugger.LLDB"
      selectedLauncherIdentifier = "Xcode.DebuggerFoundation.Launcher.LLDB"
      shouldUseLaunchSchemeArgsEnv = "YES">
      <Testables>
         <!--
            File13UITests is intentionally NOT in this scheme's test action.
            It contains only a launch-performance benchmark, and its runner
            hangs "before establishing connection" under headless
            `xcodebuild test` (and `skipped = "YES"` doesn't stop xcodebuild
            from launching it). Keeping it out means `xcodebuild test
            -scheme File13` runs the unit suite cleanly. To run the UI
            benchmark, add File13UITests back to the Test action in Xcode.
         -->
         <TestableReference
            skipped = "NO">
            <BuildableReference
               BuildableIdentifier = "primary"
               BlueprintIdentifier = "974F245D2FAE622F00A2D991"
               BuildableName = "File13Tests.xctest"
               BlueprintName = "File13Tests"
               ReferencedContainer = "container:File13.xcodeproj">
            </BuildableReference>
         </TestableReference>
      </Testables>
   </TestAction>
