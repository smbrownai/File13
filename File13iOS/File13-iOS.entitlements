<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  iOS app entitlements. Differences from the macOS app's entitlements
	  (File13/File13.entitlements) are intentional:
	   - No `com.apple.security.app-sandbox` key: iOS apps are sandboxed
	     unconditionally by the OS, no opt-in needed.
	   - No `com.apple.security.network.client`: iOS sandbox allows outbound
	     network connections by default.
	   - Same `application-groups` and `keychain-access-groups` as macOS so
	     credentials and the shared App Group `UserDefaults` flow through the
	     same identifiers.
	   - Same `ubiquity-kvstore-identifier` so settings (the allowlisted subset
	     in `CloudKVSync`) flow between Mac and iOS through the existing
	     `NSUbiquitousKeyValueStore`.
	-->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.shawnbrown.File13</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.shawnbrown.File13</string>
		<string>$(AppIdentifierPrefix)com.shawnbrown.File13.shared</string>
	</array>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)com.shawnbrown.File13</string>
</dict>
</plist>
