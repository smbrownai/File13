# IMAP Configuration
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USERNAME=your_username
IMAP_PASSWORD=your_password

# Optional auth method override for IMAP (default: LOGIN)
# Supported values: LOGIN, XOAUTH2, OAUTH2, MODERN
# IMAP_AUTH_METHOD=XOAUTH2
# Required when IMAP_AUTH_METHOD is XOAUTH2/OAUTH2/MODERN
# IMAP_ACCESS_TOKEN=your_oauth_access_token

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
